# Application
APP_NAME=Harmony Health PMS
APP_VERSION=0.1.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/harmony_health

# JWT
JWT_SECRET=change-me-to-a-secure-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Service
AI_SERVICE_BASE_URL=http://localhost:8080
AI_SERVICE_TENANT_ID=hospital_001
AI_SERVICE_SITE_ID=main_branch
AI_SERVICE_TIMEOUT=30

# Voice Service (internal auth)
VOICE_SYNC_API_KEY=change-me-to-a-secure-api-key

# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Whisper
WHISPER_MODEL_PATH=receptionist-voice-poc/model/whisper/faster-whisper-small-int8

# Piper
PIPER_MODEL_PATH=receptionist-voice-poc/voice/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=receptionist-voice-poc/voice/en_US-lessac-medium.onnx.json

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
